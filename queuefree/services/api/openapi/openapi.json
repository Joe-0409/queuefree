{
  "openapi": "3.0.0",
  "info": {
    "title": "QueueFree API",
    "description": "Batch 9B: Typed Read-Only Core OpenAPI. Exposes system, rules, and consumer core read-only endpoints (Me, Products, Queue, Tasks, Invites, Wallet, Withdrawals).",
    "version": "0.0.1"
  },
  "servers": [
    {
      "url": "http://localhost:4000",
      "description": "local"
    }
  ],
  "tags": [
    { "name": "System" },
    { "name": "Rules" },
    { "name": "ConsumerMe" },
    { "name": "ConsumerProducts" },
    { "name": "ConsumerQueue" },
    { "name": "ConsumerTasks" },
    { "name": "ConsumerInvites" },
    { "name": "ConsumerWallet" },
    { "name": "ConsumerWithdrawals" }
  ],
  "paths": {
    "/v1/health": {
      "get": {
        "tags": ["System"],
        "summary": "Health Check",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/HealthResponse" } }
            }
          }
        }
      }
    },
    "/v1/me": {
      "get": {
        "tags": ["ConsumerMe"],
        "summary": "Get User Overview",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/MeOverviewResponse" } }
            }
          }
        }
      }
    },
    "/v1/products": {
      "get": {
        "tags": ["ConsumerProducts"],
        "summary": "List Products",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ProductListResponse" } }
            }
          }
        }
      }
    },
    "/v1/products/{productId}": {
      "get": {
        "tags": ["ConsumerProducts"],
        "summary": "Get Product Detail",
        "parameters": [
          { "name": "productId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ProductDetailResponse" } }
            }
          }
        }
      }
    },
    "/v1/queue-guard": {
      "get": {
        "tags": ["ConsumerQueue"],
        "summary": "Get User Queue Guard Status",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/UserQueueGuardResponse" } }
            }
          }
        }
      }
    },
    "/v1/queue-entries": {
      "get": {
        "tags": ["ConsumerQueue"],
        "summary": "List My Queue Entries",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/QueueEntryListResponse" } }
            }
          }
        }
      }
    },
    "/v1/queue-entries/{queueEntryId}": {
      "get": {
        "tags": ["ConsumerQueue"],
        "summary": "Get Queue Entry Detail",
        "parameters": [
          { "name": "queueEntryId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/QueueEntryDetailResponse" } }
            }
          }
        }
      }
    },
    "/v1/tasks": {
      "get": {
        "tags": ["ConsumerTasks"],
        "summary": "List Available Tasks",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/TaskListResponse" } }
            }
          }
        }
      }
    },
    "/v1/invites/me": {
      "get": {
        "tags": ["ConsumerInvites"],
        "summary": "Get My Invite Overview",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/UserInviteOverviewResponse" } }
            }
          }
        }
      }
    },
    "/v1/invites/records": {
      "get": {
        "tags": ["ConsumerInvites"],
        "summary": "List My Invite Records",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/InviteRecordListResponse" } }
            }
          }
        }
      }
    },
    "/v1/wallet": {
      "get": {
        "tags": ["ConsumerWallet"],
        "summary": "Get Wallet Overview",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/WalletOverviewResponse" } }
            }
          }
        }
      }
    },
    "/v1/wallet/ledgers": {
      "get": {
        "tags": ["ConsumerWallet"],
        "summary": "List Wallet Ledgers",
        "parameters": [
          { "name": "cursor", "in": "query", "schema": { "type": "string", "nullable": true } },
          { "name": "limit", "in": "query", "schema": { "type": "number", "default": 20 } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/WalletLedgerListResponse" } }
            }
          }
        }
      }
    },
    "/v1/withdrawals": {
      "get": {
        "tags": ["ConsumerWithdrawals"],
        "summary": "List Withdrawals",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/WithdrawalListResponse" } }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["ok"] },
          "version": { "type": "string" }
        },
        "required": ["status", "version"]
      },
      "MeOverviewResponse": {
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "phoneMasked": { "type": "string" },
          "accountDeleteStatus": { "type": "string" },
          "walletActivationMethod": { "type": "string", "nullable": true }
        },
        "required": ["userId", "phoneMasked", "accountDeleteStatus"]
      },
      "ProductListItem": {
        "type": "object",
        "properties": {
          "productId": { "type": "string" },
          "title": { "type": "string" },
          "coverImageUrl": { "type": "string" },
          "priceMinor": { "type": "number" },
          "currencyCode": { "type": "string" },
          "isQueueEligible": { "type": "boolean" }
        },
        "required": ["productId", "title", "coverImageUrl", "priceMinor", "currencyCode", "isQueueEligible"]
      },
      "ProductListResponse": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/ProductListItem" } }
        },
        "required": ["items"]
      },
      "ProductDetailResponse": {
        "type": "object",
        "properties": {
          "productId": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "imageUrls": { "type": "array", "items": { "type": "string" } },
          "priceMinor": { "type": "number" },
          "currencyCode": { "type": "string" },
          "isQueueEligible": { "type": "boolean" }
        },
        "required": ["productId", "title", "description", "imageUrls", "priceMinor", "currencyCode", "isQueueEligible"]
      },
      "UserQueueGuardResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "lastCheckinAt": { "type": "string", "nullable": true },
          "validUntil": { "type": "string" }
        },
        "required": ["status", "validUntil"]
      },
      "QueueEntryListItem": {
        "type": "object",
        "properties": {
          "queueEntryId": { "type": "string" },
          "productId": { "type": "string" },
          "productTitle": { "type": "string" },
          "status": { "type": "string" },
          "activeRank": { "type": "number", "nullable": true }
        },
        "required": ["queueEntryId", "productId", "productTitle", "status"]
      },
      "QueueEntryListResponse": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/QueueEntryListItem" } }
        },
        "required": ["items"]
      },
      "QueueEntryDetailResponse": {
        "type": "object",
        "properties": {
          "queueEntryId": { "type": "string" },
          "productId": { "type": "string" },
          "productTitle": { "type": "string" },
          "status": { "type": "string" },
          "activeRank": { "type": "number", "nullable": true },
          "enteredAt": { "type": "string" }
        },
        "required": ["queueEntryId", "productId", "productTitle", "status", "enteredAt"]
      },
      "TaskListResponse": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/TaskListItem" } }
        },
        "required": ["items"]
      },
      "TaskListItem": {
        "type": "object",
        "properties": {
          "taskId": { "type": "string" },
          "title": { "type": "string" },
          "rewardCashbackAmountMinor": { "type": "number" },
          "isClaimed": { "type": "boolean" }
        },
        "required": ["taskId", "title", "rewardCashbackAmountMinor", "isClaimed"]
      },
      "UserInviteOverviewResponse": {
        "type": "object",
        "properties": {
          "inviteCode": { "type": "string" },
          "totalInvitedCount": { "type": "number" },
          "effectiveInvitedCount": { "type": "number" }
        },
        "required": ["inviteCode", "totalInvitedCount", "effectiveInvitedCount"]
      },
      "InviteRecordListResponse": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/InviteRecordListItem" } }
        },
        "required": ["items"]
      },
      "InviteRecordListItem": {
        "type": "object",
        "properties": {
          "relationId": { "type": "string" },
          "inviteePhoneMasked": { "type": "string" },
          "status": { "type": "string" },
          "createdAt": { "type": "string" }
        },
        "required": ["relationId", "inviteePhoneMasked", "status", "createdAt"]
      },
      "WalletOverviewResponse": {
        "type": "object",
        "properties": {
          "balanceMinor": { "type": "number" },
          "pendingCashbackMinor: number": { "type": "number" },
          "totalWithdrawnMinor": { "type": "number" }
        },
        "required": ["balanceMinor", "pendingCashbackMinor: number", "totalWithdrawnMinor"]
      },
      "WalletLedgerListResponse": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/WalletLedgerListItem" } },
          "nextCursor": { "type": "string", "nullable": true }
        },
        "required": ["items"]
      },
      "WalletLedgerListItem": {
        "type": "object",
        "properties": {
          "ledgerId": { "type": "string" },
          "amountMinor": { "type": "number" },
          "type": { "type": "string" },
          "description": { "type": "string" },
          "createdAt": { "type": "string" }
        },
        "required": ["ledgerId", "amountMinor", "type", "description", "createdAt"]
      },
      "WithdrawalListResponse": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/WithdrawalListItem" } }
        },
        "required": ["items"]
      },
      "WithdrawalListItem": {
        "type": "object",
        "properties": {
          "withdrawalId": { "type": "string" },
          "amountMinor": { "type": "number" },
          "status": { "type": "string" },
          "createdAt": { "type": "string" }
        },
        "required": ["withdrawalId", "amountMinor", "status", "createdAt"]
      }
    }
  }
}
