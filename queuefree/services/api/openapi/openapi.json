{
  "openapi": "3.0.0",
  "info": {
    "title": "QueueFree API",
    "description": "Batch 9 Final: Typed Read-Only Core OpenAPI (Consumer & Admin).",
    "version": "0.1.0"
  },
  "servers": [
    { "url": "http://localhost:4000", "description": "local" }
  ],
  "paths": {
    "/v1/health": {
      "get": {
        "tags": ["System"],
        "summary": "Health Check",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/HealthResponse" } } }
          }
        }
      }
    },
    "/v1/me": {
      "get": {
        "tags": ["ConsumerMe"],
        "summary": "Get User Overview",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MeOverviewResponse" } } }
          }
        }
      }
    },
    "/v1/products": {
      "get": {
        "tags": ["ConsumerProducts"],
        "summary": "List Products",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProductListResponse" } } }
          }
        }
      }
    },
    "/v1/products/{productId}": {
      "get": {
        "tags": ["ConsumerProducts"],
        "summary": "Get Product Detail",
        "parameters": [
          { "name": "productId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProductDetailResponse" } } }
          }
        }
      }
    },
    "/v1/queue-guard": {
      "get": {
        "tags": ["ConsumerQueue"],
        "summary": "Get Queue Guard Status",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserQueueGuardResponse" } } }
          }
        }
      }
    },
    "/v1/queue-entries": {
      "get": {
        "tags": ["ConsumerQueue"],
        "summary": "List My Queue Entries",
        "parameters": [
          { "name": "cursor", "in": "query", "schema": { "type": "string", "nullable": true } },
          { "name": "limit", "in": "query", "schema": { "type": "number", "default": 20 } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/QueueEntryListResponse" } } }
          }
        }
      }
    },
    "/v1/tasks": {
      "get": {
        "tags": ["ConsumerTasks"],
        "summary": "List Available Tasks",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TaskListResponse" } } }
          }
        }
      }
    },
    "/v1/invites/me": {
      "get": {
        "tags": ["ConsumerInvites"],
        "summary": "Get My Invite Overview",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserInviteOverviewResponse" } } }
          }
        }
      }
    },
    "/v1/wallet": {
      "get": {
        "tags": ["ConsumerWallet"],
        "summary": "Get Wallet Overview",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WalletOverviewResponse" } } }
          }
        }
      }
    },
    "/v1/admin/dashboard/summary": {
      "get": {
        "tags": ["AdminDashboard"],
        "summary": "Admin Dashboard Summary",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AdminDashboardSummaryResponse" } } }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["ok"] },
          "version": { "type": "string" }
        },
        "required": ["status", "version"]
      },
      "MeOverviewResponse": {
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "phoneMasked": { "type": "string" },
          "inviteCode": { "type": "string" },
          "walletActivated": { "type": "boolean" },
          "accountDeleteStatus": { "type": "string" },
          "ruleVersion": { "type": "string" }
        },
        "required": ["userId", "phoneMasked", "inviteCode", "walletActivated", "accountDeleteStatus", "ruleVersion"]
      },
      "ProductListItem": {
        "type": "object",
        "properties": {
          "productId": { "type": "string" },
          "title": { "type": "string" },
          "coverImageUrl": { "type": "string" },
          "priceMinor": { "type": "number" },
          "currency": { "type": "string" },
          "queueEnabled": { "type": "boolean" },
          "soldOut": { "type": "boolean" }
        },
        "required": ["productId", "title", "coverImageUrl", "priceMinor", "currency", "queueEnabled", "soldOut"]
      },
      "ProductListResponse": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/ProductListItem" } }
        },
        "required": ["items"]
      },
      "ProductDetailResponse": {
        "type": "object",
        "properties": {
          "productId": { "type": "string" },
          "title": { "type": "string" },
          "descriptionText": { "type": "string" },
          "coverImageUrl": { "type": "string" },
          "priceMinor": { "type": "number" },
          "currency": { "type": "string" },
          "queueEnabled": { "type": "boolean" },
          "soldOut": { "type": "boolean" }
        },
        "required": ["productId", "title", "descriptionText", "coverImageUrl", "priceMinor", "currency", "queueEnabled", "soldOut"]
      },
      "UserQueueGuardResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "validUntil": { "type": "string" },
          "activeEntriesCount": { "type": "number" },
          "frozenEntriesCount": { "type": "number" }
        },
        "required": ["status", "validUntil", "activeEntriesCount", "frozenEntriesCount"]
      },
      "QueueEntryListItem": {
        "type": "object",
        "properties": {
          "queueEntryId": { "type": "string" },
          "productId": { "type": "string" },
          "productTitle": { "type": "string" },
          "status": { "type": "string" },
          "activeRank": { "type": "number", "nullable": true },
          "boostUsedCount": { "type": "number" }
        },
        "required": ["queueEntryId", "productId", "productTitle", "status", "boostUsedCount"]
      },
      "QueueEntryListResponse": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/QueueEntryListItem" } },
          "nextCursor": { "type": "string", "nullable": true }
        },
        "required": ["items"]
      },
      "TaskListResponse": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/TaskListItem" } }
        },
        "required": ["items"]
      },
      "TaskListItem": {
        "type": "object",
        "properties": {
          "taskId": { "type": "string" },
          "title": { "type": "string" },
          "rewardSummaryText": { "type": "string" },
          "claimed": { "type": "boolean" }
        },
        "required": ["taskId", "title", "rewardSummaryText", "claimed"]
      },
      "UserInviteOverviewResponse": {
        "type": "object",
        "properties": {
          "inviteCode": { "type": "string" },
          "totalInviteCount": { "type": "number" },
          "effectiveInviteCount": { "type": "number" }
        },
        "required": ["inviteCode", "totalInviteCount", "effectiveInviteCount"]
      },
      "WalletOverviewResponse": {
        "type": "object",
        "properties": {
          "walletActivated": { "type": "boolean" },
          "availableBalanceMinor": { "type": "number" },
          "pendingBalanceMinor": { "type": "number" },
          "currency": { "type": "string" }
        },
        "required": ["walletActivated", "availableBalanceMinor", "pendingBalanceMinor", "currency"]
      },
      "AdminDashboardSummaryResponse": {
        "type": "object",
        "properties": {
          "paidOrderCountToday": { "type": "number" },
          "activeQueueEntryCount": { "type": "number" },
          "pendingWithdrawalCount": { "type": "number" }
        },
        "required": ["paidOrderCountToday", "activeQueueEntryCount", "pendingWithdrawalCount"]
      }
    }
  }
}
