{
  "openapi": "3.0.0",
  "info": {
    "title": "QueueFree API",
    "description": "Batch 9 Final: Typed Read-Only Core OpenAPI (Consumer & Admin).",
    "version": "0.1.0"
  },
  "servers": [
    { "url": "http://localhost:4000", "description": "local" }
  ],
  "paths": {
    "/v1/health": {
      "get": {
        "tags": ["System"],
        "summary": "Health Check",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/HealthResponse" } } }
          }
        }
      }
    },
    "/v1/me": {
      "get": {
        "tags": ["ConsumerMe"],
        "summary": "Get User Overview",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MeOverviewResponse" } } }
          }
        }
      }
    },
    "/v1/products": {
      "get": {
        "tags": ["ConsumerProducts"],
        "summary": "List Products",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProductListResponse" } } }
          }
        }
      }
    },
    "/v1/products/{productId}": {
      "get": {
        "tags": ["ConsumerProducts"],
        "summary": "Get Product Detail",
        "parameters": [
          { "name": "productId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProductDetailResponse" } } }
          }
        }
      }
    },
    "/v1/queue-guard": {
      "get": {
        "tags": ["ConsumerQueue"],
        "summary": "Get Queue Guard Status",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserQueueGuardResponse" } } }
          }
        }
      }
    },
    "/v1/queue-entries": {
      "get": {
        "tags": ["ConsumerQueue"],
        "summary": "List My Queue Entries",
        "parameters": [
          { "name": "cursor", "in": "query", "schema": { "type": "string", "nullable": true } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/QueueEntryListResponse" } } }
          }
        }
      }
    },
    "/v1/queue-entries/{queueEntryId}": {
      "get": {
        "tags": ["ConsumerQueue"],
        "summary": "Get Queue Entry Detail",
        "parameters": [
          { "name": "queueEntryId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/QueueEntryDetailResponse" } } }
          }
        }
      }
    },
    "/v1/tasks": {
      "get": {
        "tags": ["ConsumerTasks"],
        "summary": "List Available Tasks",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TaskListResponse" } } }
          }
        }
      }
    },
    "/v1/invites/me": {
      "get": {
        "tags": ["ConsumerInvites"],
        "summary": "Get My Invite Overview",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserInviteOverviewResponse" } } }
          }
        }
      }
    },
    "/v1/invites/records": {
      "get": {
        "tags": ["ConsumerInvites"],
        "summary": "List My Invite Records",
        "parameters": [
          { "name": "cursor", "in": "query", "schema": { "type": "string", "nullable": true } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/InviteRecordListResponse" } } }
          }
        }
      }
    },
    "/v1/wallet": {
      "get": {
        "tags": ["ConsumerWallet"],
        "summary": "Get Wallet Overview",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WalletOverviewResponse" } } }
          }
        }
      }
    },
    "/v1/wallet/ledgers": {
      "get": {
        "tags": ["ConsumerWallet"],
        "summary": "List Wallet Ledgers",
        "parameters": [
          { "name": "cursor", "in": "query", "schema": { "type": "string", "nullable": true } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WalletLedgerListResponse" } } }
          }
        }
      }
    },
    "/v1/withdrawals": {
      "get": {
        "tags": ["ConsumerWithdrawals"],
        "summary": "List Withdrawals",
        "parameters": [
          { "name": "cursor", "in": "query", "schema": { "type": "string", "nullable": true } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WithdrawalListResponse" } } }
          }
        }
      }
    },
    "/v1/admin/dashboard/summary": {
      "get": {
        "tags": ["AdminDashboard"],
        "summary": "Admin Dashboard Summary",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AdminDashboardSummaryResponse" } } }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["ok"] },
          "version": { "type": "string" }
        },
        "required": ["status", "version"]
      },
      "MeOverviewResponse": {
        "type": "object",
        "properties": {
          "userId": { "type": "string", "format": "uuid" },
          "phoneMasked": { "type": "string" },
          "inviteCode": { "type": "string" },
          "walletActivated": { "type": "boolean" },
          "walletActivationMethod": { "type": "string", "nullable": true },
          "accountDeleteStatus": { "type": "string" },
          "marketCode": { "type": "string" },
          "currency": { "type": "string" },
          "timezone": { "type": "string" },
          "ruleVersion": { "type": "string" }
        },
        "required": ["userId", "phoneMasked", "inviteCode", "walletActivated", "accountDeleteStatus", "marketCode", "currency", "timezone", "ruleVersion"]
      },
      "ProductListItem": {
        "type": "object",
        "properties": {
          "productId": { "type": "string", "format": "uuid" },
          "title": { "type": "string" },
          "coverImageUrl": { "type": "string" },
          "priceMinor": { "type": "integer" },
          "currency": { "type": "string" },
          "defaultCashbackCapMinor": { "type": "integer" },
          "queueEnabled": { "type": "boolean" },
          "soldOut": { "type": "boolean" }
        },
        "required": ["productId", "title", "coverImageUrl", "priceMinor", "currency", "defaultCashbackCapMinor", "queueEnabled", "soldOut"]
      },
      "ProductListResponse": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/ProductListItem" } }
        },
        "required": ["items"]
      },
      "ProductDetailSku": {
        "type": "object",
        "properties": {
          "skuId": { "type": "string", "format": "uuid" },
          "label": { "type": "string" },
          "priceMinor": { "type": "integer" },
          "soldOut": { "type": "boolean" }
        },
        "required": ["skuId", "label", "priceMinor", "soldOut"]
      },
      "ProductDetailResponse": {
        "type": "object",
        "properties": {
          "productId": { "type": "string", "format": "uuid" },
          "title": { "type": "string" },
          "descriptionText": { "type": "string" },
          "coverImageUrl": { "type": "string" },
          "galleryImageUrls": { "type": "array", "items": { "type": "string" } },
          "priceMinor": { "type": "integer" },
          "currency": { "type": "string" },
          "defaultCashbackCapMinor": { "type": "integer" },
          "queueEnabled": { "type": "boolean" },
          "soldOut": { "type": "boolean" },
          "maxOrderQty": { "type": "integer" },
          "skus": { "type": "array", "items": { "$ref": "#/components/schemas/ProductDetailSku" } }
        },
        "required": ["productId", "title", "descriptionText", "coverImageUrl", "galleryImageUrls", "priceMinor", "currency", "defaultCashbackCapMinor", "queueEnabled", "soldOut", "maxOrderQty", "skus"]
      },
      "UserQueueGuardResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "validUntil": { "type": "string", "format": "date-time" },
          "graceUntil": { "type": "string", "format": "date-time" },
          "lastCheckinAt": { "type": "string", "format": "date-time", "nullable": true },
          "canCheckInNow": { "type": "boolean" },
          "activeEntriesCount": { "type": "integer" },
          "frozenEntriesCount": { "type": "integer" }
        },
        "required": ["status", "validUntil", "graceUntil", "canCheckInNow", "activeEntriesCount", "frozenEntriesCount"]
      },
      "QueueEntryListItem": {
        "type": "object",
        "properties": {
          "queueEntryId": { "type": "string", "format": "uuid" },
          "orderId": { "type": "string", "format": "uuid" },
          "productId": { "type": "string", "format": "uuid" },
          "productTitle": { "type": "string" },
          "productCoverImageUrl": { "type": "string" },
          "quantity": { "type": "integer" },
          "status": { "type": "string" },
          "activeRank": { "type": "integer", "nullable": true },
          "boostUsedCount": { "type": "integer" },
          "canBoost": { "type": "boolean" },
          "isInProtectZone": { "type": "boolean" },
          "nextSettlementSlotAt": { "type": "string", "format": "date-time", "nullable": true },
          "finalCashbackMinor": { "type": "integer", "nullable": true },
          "currency": { "type": "string" }
        },
        "required": ["queueEntryId", "orderId", "productId", "productTitle", "productCoverImageUrl", "quantity", "status", "boostUsedCount", "canBoost", "isInProtectZone", "currency"]
      },
      "QueueEntryListResponse": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/QueueEntryListItem" } },
          "nextCursor": { "type": "string", "nullable": true }
        },
        "required": ["items"]
      },
      "QueueEntryTimelineItem": {
        "type": "object",
        "properties": {
          "timelineId": { "type": "string", "format": "uuid" },
          "occurredAt": { "type": "string", "format": "date-time" },
          "title": { "type": "string" },
          "descriptionText": { "type": "string" }
        },
        "required": ["timelineId", "occurredAt", "title", "descriptionText"]
      },
      "QueueEntryDetailResponse": {
        "type": "object",
        "properties": {
          "queueEntryId": { "type": "string", "format": "uuid" },
          "orderId": { "type": "string", "format": "uuid" },
          "productId": { "type": "string", "format": "uuid" },
          "productTitle": { "type": "string" },
          "productCoverImageUrl": { "type": "string" },
          "productSkuLabel": { "type": "string" },
          "quantity": { "type": "integer" },
          "paidAmountMinor": { "type": "integer" },
          "currency": { "type": "string" },
          "status": { "type": "string" },
          "activeRank": { "type": "integer", "nullable": true },
          "boostUsedCount": { "type": "integer" },
          "canBoost": { "type": "boolean" },
          "isInProtectZone": { "type": "boolean" },
          "queueGuardStatus": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "wonSettlementSlotAt": { "type": "string", "format": "date-time", "nullable": true },
          "cashbackAvailableAt": { "type": "string", "format": "date-time", "nullable": true },
          "finalCashbackMinor": { "type": "integer", "nullable": true },
          "timeline": { "type": "array", "items": { "$ref": "#/components/schemas/QueueEntryTimelineItem" } }
        },
        "required": ["queueEntryId", "orderId", "productId", "productTitle", "productCoverImageUrl", "productSkuLabel", "quantity", "paidAmountMinor", "currency", "status", "boostUsedCount", "canBoost", "isInProtectZone", "queueGuardStatus", "createdAt", "timeline"]
      },
      "TaskListItem": {
        "type": "object",
        "properties": {
          "taskId": { "type": "string", "format": "uuid" },
          "title": { "type": "string" },
          "descriptionText": { "type": "string" },
          "categoryLabel": { "type": "string" },
          "rewardSummaryText": { "type": "string" },
          "progressCurrent": { "type": "integer" },
          "progressTarget": { "type": "integer" },
          "claimable": { "type": "boolean" },
          "claimed": { "type": "boolean" },
          "expiresAt": { "type": "string", "format": "date-time", "nullable": true }
        },
        "required": ["taskId", "title", "descriptionText", "categoryLabel", "rewardSummaryText", "progressCurrent", "progressTarget", "claimable", "claimed"]
      },
      "TaskListResponse": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/TaskListItem" } }
        },
        "required": ["items"]
      },
      "UserInviteOverviewResponse": {
        "type": "object",
        "properties": {
          "inviteCode": { "type": "string" },
          "inviteLink": { "type": "string" },
          "canBindInviteCode": { "type": "boolean" },
          "bindWindowEndsAt": { "type": "string", "format": "date-time", "nullable": true },
          "totalInviteCount": { "type": "integer" },
          "pendingEffectiveInviteCount": { "type": "integer" },
          "effectiveInviteCount": { "type": "integer" },
          "invalidInviteCount": { "type": "integer" },
          "walletActivated": { "type": "boolean" },
          "walletActivationMethod": { "type": "string", "nullable": true }
        },
        "required": ["inviteCode", "inviteLink", "canBindInviteCode", "totalInviteCount", "pendingEffectiveInviteCount", "effectiveInviteCount", "invalidInviteCount", "walletActivated"]
      },
      "InviteRecordListItem": {
        "type": "object",
        "properties": {
          "relationId": { "type": "string", "format": "uuid" },
          "inviteeMaskedPhone": { "type": "string" },
          "status": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "effectiveAt": { "type": "string", "format": "date-time", "nullable": true },
          "invalidReasonText": { "type": "string", "nullable": true }
        },
        "required": ["relationId", "inviteeMaskedPhone", "status", "createdAt"]
      },
      "InviteRecordListResponse": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/InviteRecordListItem" } },
          "nextCursor": { "type": "string", "nullable": true }
        },
        "required": ["items"]
      },
      "WalletOverviewResponse": {
        "type": "object",
        "properties": {
          "walletActivated": { "type": "boolean" },
          "activationMethod": { "type": "string", "nullable": true },
          "pendingBalanceMinor": { "type": "integer" },
          "availableBalanceMinor": { "type": "integer" },
          "frozenBalanceMinor": { "type": "integer" },
          "currency": { "type": "string" },
          "canWithdraw": { "type": "boolean" },
          "hasSettlementException": { "type": "boolean" }
        },
        "required": ["walletActivated", "pendingBalanceMinor", "availableBalanceMinor", "frozenBalanceMinor", "currency", "canWithdraw", "hasSettlementException"]
      },
      "WalletLedgerListItem": {
        "type": "object",
        "properties": {
          "ledgerId": { "type": "string", "format": "uuid" },
          "title": { "type": "string" },
          "balanceBucket": { "type": "string" },
          "deltaMinor": { "type": "integer" },
          "createdAt": { "type": "string", "format": "date-time" },
          "relatedOrderId": { "type": "string", "format": "uuid", "nullable": true },
          "relatedWithdrawalId": { "type": "string", "format": "uuid", "nullable": true },
          "noteText": { "type": "string", "nullable": true }
        },
        "required": ["ledgerId", "title", "balanceBucket", "deltaMinor", "createdAt"]
      },
      "WalletLedgerListResponse": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/WalletLedgerListItem" } },
          "nextCursor": { "type": "string", "nullable": true }
        },
        "required": ["items"]
      },
      "WithdrawalListItem": {
        "type": "object",
        "properties": {
          "withdrawalId": { "type": "string", "format": "uuid" },
          "amountMinor": { "type": "integer" },
          "currency": { "type": "string" },
          "status": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "rejectReasonText": { "type": "string", "nullable": true }
        },
        "required": ["withdrawalId", "amountMinor", "currency", "status", "createdAt", "updatedAt"]
      },
      "WithdrawalListResponse": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/WithdrawalListItem" } },
          "nextCursor": { "type": "string", "nullable": true }
        },
        "required": ["items"]
      },
      "AdminDashboardSummaryResponse": {
        "type": "object",
        "properties": {
          "paidOrderCountToday": { "type": "integer" },
          "activeQueueEntryCount": { "type": "integer" },
          "frozenQueueEntryCount": { "type": "integer" },
          "scheduledSettlementSlotCount": { "type": "integer" },
          "runningSettlementSlotCount": { "type": "integer" },
          "pendingWithdrawalCount": { "type": "integer" },
          "pendingRiskCaseCount": { "type": "integer" }
        },
        "required": ["paidOrderCountToday", "activeQueueEntryCount", "frozenQueueEntryCount", "scheduledSettlementSlotCount", "runningSettlementSlotCount", "pendingWithdrawalCount", "pendingRiskCaseCount"]
      }
    }
  }
}
