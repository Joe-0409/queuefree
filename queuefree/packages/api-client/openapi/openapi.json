{
  "openapi": "3.0.3",
  "info": {
    "title": "QueueFree API",
    "version": "1.2"
  },
  "paths": {
    "/v1/health": {
      "get": {
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/v1/system/runtime-config": {
      "get": {
        "operationId": "getRuntimeConfig",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/v1/rules": {
      "get": {
        "operationId": "listRules",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/v1/rules/{slug}": {
      "get": {
        "operationId": "getRuleBySlug",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  }
}
