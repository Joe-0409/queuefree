  "info": {
    "title": "QueueFree API",
    "description": "Initial C-end OpenAPI surface for QueueFree. This batch exposes system-level endpoints plus the minimum public rules endpoints needed by Web rules pages and packages/api-client.",
    "version": "0.0.1",
    "contact": {}
  },
  "tags": [
    {
      "name": "System",
      "description": "System health and public runtime configuration."
    },
    {
      "name": "Rules",
      "description": "Public rules center documents for Web and App."
    }
  ],
  "servers": [
    {
      "url": "http://localhost:4000",
      "description": "local"
    },
    {
      "url": "https://dev-api.queuefree.com",
      "description": "dev"
    },
    {
      "url": "https://stg-api.queuefree.com",
      "description": "staging"
    },
    {
      "url": "https://api.queuefree.com",
      "description": "prod"
    }
  ],
  "components": {
    "schemas": {
      "AppEnv": {
        "type": "string",
        "enum": [
          "local",
          "dev",
          "test",
          "staging",
          "prod"
        ]
      },
      "HealthResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok"
            ],
            "example": "ok"
          },
          "service": {
            "type": "string",
            "example": "@queuefree/api"
          },
          "version": {
            "type": "string",
            "example": "0.0.1"
          },
          "environment": {
            "example": "local",
            "allOf": [
              {
                "$ref": "#/components/schemas/AppEnv"
              }
            ]
          },
          "timestamp": {
            "type": "string",
            "example": "2026-03-11T00:00:00.000Z",
            "format": "date-time"
          }
        },
        "required": [
          "status",
          "service",
          "version",
          "environment",
          "timestamp"
        ]
      },
      "ApiErrorResponseDto": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "INTERNAL_SERVER_ERROR"
          },
          "message": {
            "type": "string",
            "example": "Unexpected server error."
          },
          "requestId": {
            "type": "string",
            "example": "req_demo_123"
          },
          "details": {
            "type": "object",
            "additionalProperties": true,
            "description": "Opaque structured error details for debugging or validation feedback."
          }
        },
        "required": [
          "code",
          "message"
        ]
      },
      "RuntimeConfigResponseDto": {
        "type": "object",
        "properties": {
          "marketCode": {
            "type": "string",
            "example": "PH"
          },
          "currencyCode": {
            "type": "string",
            "example": "PHP"
          },
          "timezone": {
            "type": "string",
            "example": "Asia/Manila"
          },
          "locale": {
            "type": "string",
            "example": "en-PH"
          },
          "language": {
            "type": "string",
            "example": "English"
          },
          "ruleVersion": {
            "type": "string",
            "example": "v1.2"
          },
          "rewardedAdsEnabled": {
            "type": "boolean",
            "example": false
          }
        },
        "required": [
          "marketCode",
          "currencyCode",
          "timezone",
          "locale",
          "language",
          "ruleVersion",
          "rewardedAdsEnabled"
        ]
      },
      "RuleListItemDto": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string",
            "example": "queue"
          },
          "title": {
            "type": "string",
            "example": "Queue Rules"
          },
          "summary": {
            "type": "string",
            "example": "How queue ranking, protection, boost, and settlement slots work."
          },
          "updatedAt": {
            "type": "string",
            "example": "2026-03-11T00:00:00.000Z",
            "format": "date-time"
          },
          "ruleVersion": {
            "type": "string",
            "example": "v1.2"
          }
        },
        "required": [
          "slug",
          "title",
          "summary",
          "updatedAt",
          "ruleVersion"
        ]
      },
      "RuleDetailResponseDto": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string",
            "example": "queue"
          },
          "title": {
            "type": "string",
            "example": "Queue Rules"
          },
          "sections": {
            "example": [
              "Queue rank is based on effective active entries only.",
              "Settlement runs on fixed public slots."
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "updatedAt": {
            "type": "string",
            "example": "2026-03-11T00:00:00.000Z",
            "format": "date-time"
          },
          "ruleVersion": {
            "type": "string",
            "example": "v1.2"
          }
        },
        "required": [
          "slug",
          "title",
          "sections",
          "updatedAt",
          "ruleVersion"
        ]
      },
      "MeOverviewResponseDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "phoneMasked": {
            "type": "string"
          },
          "inviteCode": {
            "type": "string"
          },
          "walletActivated": {
            "type": "boolean"
          },
          "walletActivationMethod": {
            "type": "object",
            "nullable": true
          },
          "accountDeleteStatus": {
            "type": "string"
          },
          "marketCode": {
            "type": "string"
          },
          "currency": {
            "type": "string"
          },
          "timezone": {
            "type": "string"
          },
          "ruleVersion": {
            "type": "string"
          }
        },
        "required": [
          "userId",
          "phoneMasked",
          "inviteCode",
          "walletActivated",
          "walletActivationMethod",
          "accountDeleteStatus",
          "marketCode",
          "currency",
          "timezone",
          "ruleVersion"
        ]
      },
      "ProductListItemDto": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
