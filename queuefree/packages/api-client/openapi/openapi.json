            "type": "number"
          },
          "queueEnabled": {
            "type": "boolean"
          },
          "soldOut": {
            "type": "boolean"
          }
        },
        "required": [
          "productId",
          "title",
          "coverImageUrl",
          "priceMinor",
          "currency",
          "defaultCashbackCapMinor",
          "queueEnabled",
          "soldOut"
